import pygame
import random
import sys

pygame.init()

# Configurações da Tela
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Chronos Express - Platformer Edition v5.0")
clock = pygame.time.Clock()

# Cores Cyberpunk
BLACK = (10, 10, 15)
WHITE = (240, 240, 240)
CYAN = (0, 255, 255)       # Jogador
YELLOW = (255, 255, 0)     # Bateria
GREEN = (0, 255, 120)      # Máquina do Tempo (Base)
RED = (255, 50, 70)        # Inimigos
GRAY = (60, 60, 75)        # Plataformas
BLUE = (50, 150, 255)      # Escudo

# Fontes
font_sm = pygame.font.SysFont("Arial", 20, bold=True)
font_md = pygame.font.SysFont("Arial", 28, bold=True)
font_lg = pygame.font.SysFont("Arial", 55, bold=True)

# Estados do Jogo
STATE_MENU = "MENU"
STATE_PLAYING = "PLAYING"
STATE_GAME_OVER = "GAME_OVER"
current_state = STATE_MENU

# Variáveis Globais
LOOP_TIME = 30.0
time_left = LOOP_TIME
deliveries_made = 0

class Player:
    def __init__(self):
        self.size = 24
        self.rect = pygame.Rect(0, 0, self.size, self.size)
        
        # Física de Plataforma
        self.speed_x = 4.5
        self.vel_y = 0
        self.gravity = 0.6
        self.jump_strength = -13
        self.on_ground = False
        
        self.has_item = False
        self.shield_timer = 0.0
        self.reset_pos()

    def reset_pos(self):
        # Nasce seguro no chão do mapa
        self.rect.x = WIDTH // 2
        self.rect.y = HEIGHT - 80
        self.vel_y = 0
        self.shield_timer = 0.0
        self.has_item = False

    def move(self, keys, platforms):
        # 1. Movimento Horizontal
        move_x = 0
        if keys[pygame.K_LEFT] or keys[pygame.K_a]: move_x = -self.speed_x
        if keys[pygame.K_RIGHT] or keys[pygame.K_d]: move_x = self.speed_x
        
        self.rect.x += move_x
        # Colisão Horizontal
        for plat in platforms:
            if self.rect.colliderect(plat):
                if move_x > 0: self.rect.right = plat.left
                if move_x < 0: self.rect.left = plat.right

        # 2. Pulo e Gravidade
        if (keys[pygame.K_UP] or keys[pygame.K_w] or keys[pygame.K_SPACE]) and self.on_ground:
            self.vel_y = self.jump_strength
            self.on_ground = False

        self.vel_y += self.gravity
        # Limite de velocidade de queda (terminal velocity)
        if self.vel_y > 15: self.vel_y = 15
        
        self.rect.y += self.vel_y
        self.on_ground = False
        
        # Colisão Vertical
        for plat in platforms:
            if self.rect.colliderect(plat):
                if self.vel_y > 0: # Caindo
                    self.rect.bottom = plat.top
                    self.vel_y = 0
                    self.on_ground = True
                elif self.vel_y < 0: # Subindo (Bateu a cabeça)
                    self.rect.top = plat.bottom
                    self.vel_y = 0

        # Limites Laterais da Tela
        if self.rect.left < 0: self.rect.left = 0
        if self.rect.right > WIDTH: self.rect.right = WIDTH

    def draw(self, surface):
        pygame.draw.rect(surface, CYAN, self.rect)
        if self.has_item:
            pygame.draw.rect(surface, YELLOW, self.rect, 2)
        if self.shield_timer > 0:
            pygame.draw.rect(surface, BLUE, (self.rect.x - 4, self.rect.y - 4, self.size + 8, self.size + 8), 3)

class Collectible:
    def __init__(self):
        self.size = 20
        self.rect = pygame.Rect(0, 0, self.size, self.size)

    def spawn(self, platforms):
        # Escolhe uma plataforma flutuante (evita o chão principal index 0 para ficar divertido)
        chosen_plat = random.choice(platforms[1:])
        # Coloca o item exatamente em cima da plataforma escolhida
        self.rect.centerx = random.randint(chosen_plat.left + 20, chosen_plat.right - 20)
        self.rect.bottom = chosen_plat.top - 5

    def draw(self, surface):
        pygame.draw.ellipse(surface, YELLOW, self.rect)

class PowerUp:
    def __init__(self):
        self.size = 18
        self.rect = pygame.Rect(0, 0, self.size, self.size)
        self.active = False

    def spawn(self, platforms):
        self.active = True
        chosen_plat = random.choice(platforms[1:])
        self.rect.centerx = random.randint(chosen_plat.left + 20, chosen_plat.right - 20)
        self.rect.bottom = chosen_plat.top - 5

    def draw(self, surface):
        if self.active:
            pygame.draw.rect(surface, BLUE, self.rect)
            pygame.draw.rect(surface, WHITE, self.rect, 1)

class Enemy:
    def __init__(self):
        self.size = 20
        self.rect = pygame.Rect(0, 0, self.size, self.size)
        self.speed_x = random.choice([-3, -2, 2, 3])
        self.speed_y = random.choice([-2, 2])
        self.rect.x = random.randint(200, WIDTH - 200)
        self.rect.y = random.randint(100, 300)

    def update(self):
        # Inimigos flutuam pelo cenário quicando nas bordas
        self.rect.x += self.speed_x
        self.rect.y += self.speed_y

        if self.rect.left <= 0 or self.rect.right >= WIDTH: self.speed_x *= -1
        if self.rect.top <= 0 or self.rect.bottom >= HEIGHT - 100: self.speed_y *= -1

    def draw(self, surface):
        pygame.draw.rect(surface, RED, self.rect)
        pygame.draw.rect(surface, WHITE, self.rect, 1)

# --- ARQUITETURA DO MAPA (Plataformas Fixas) ---
def build_level():
    plats = [
        pygame.Rect(0, HEIGHT - 40, WIDTH, 40),      # Chão Principal
        pygame.Rect(100, 460, 200, 20),              # Camada Baixa Esq
        pygame.Rect(500, 460, 200, 20),              # Camada Baixa Dir
        pygame.Rect(300, 340, 200, 20),              # Centro Flutuante
        pygame.Rect(50, 220, 180, 20),               # Topo Esquerda (Onde fica a base!)
        pygame.Rect(570, 220, 180, 20)               # Topo Direita
    ]
    return plats

# Inicialização de Objetos
platforms = build_level()
base_rect = pygame.Rect(70, 160, 70, 60) # Fixa no topo da plataforma superior esquerda
player = Player()
item = Collectible()
powerup = PowerUp()
enemies = [Enemy()]

def reset_full_game():
    global deliveries_made, time_left, enemies
    deliveries_made = 0
    time_left = LOOP_TIME
    player.speed_x = 4.5
    player.reset_pos()
    powerup.active = False
    item.spawn(platforms)
    enemies = [Enemy()]

item.spawn(platforms)
last_ticks = pygame.time.get_ticks()

running = True
while running:
    current_ticks = pygame.time.get_ticks()
    dt = (current_ticks - last_ticks) / 1000.0
    last_ticks = current_ticks

    if current_state == STATE_MENU:
        screen.fill(BLACK)
        title_txt = font_lg.render("CHRONOS PLATFORM", True, CYAN)
        subtitle_txt = font_md.render("Pressione ESPAÇO para Saltar", True, WHITE)
        screen.blit(title_txt, (WIDTH//2 - title_txt.get_width()//2, HEIGHT//3))
        screen.blit(subtitle_txt, (WIDTH//2 - subtitle_txt.get_width()//2, HEIGHT//2))
        pygame.display.flip()
        
        for event in pygame.event.get():
            if event.type == pygame.QUIT: running = False
            if event.type == pygame.KEYDOWN and event.key == pygame.K_SPACE:
                reset_full_game()
                current_state = STATE_PLAYING

    elif current_state == STATE_PLAYING:
        time_left -= dt
        if player.shield_timer > 0: player.shield_timer -= dt
        
        # Piscar Vermelho em urgência
        if time_left <= 5.0 and int(time_left * 6) % 2 == 0:
            screen.fill((40, 12, 15)) 
        else:
            screen.fill(BLACK)

        for event in pygame.event.get():
            if event.type == pygame.QUIT: running = False

        keys = pygame.key.get_pressed()
        player.move(keys, platforms)
        for enemy in enemies: enemy.update()

        # Coleta Bateria
        if not player.has_item and player.rect.colliderect(item.rect):
            player.has_item = True

        # Coleta Escudo
        if powerup.active and player.rect.colliderect(powerup.rect):
            player.shield_timer = 5.0 
            powerup.active = False

        # Entrega na Base Temporal (Portão Verde no topo esquerdo)
        if player.has_item and player.rect.colliderect(base_rect):
            deliveries_made += 1
            player.has_item = False
            player.speed_x += 0.4 # Aumenta velocidade de corrida!
            time_left = min(LOOP_TIME, time_left + 8.0) 
            item.spawn(platforms) # Nova bateria em plataforma aleatória
            
            if not powerup.active and random.random() <= 0.35:
                powerup.spawn(platforms)

            if deliveries_made % 4 == 0:
                enemies.append(Enemy())

        # Colisão Inimigo (Tira Tempo)
        for enemy in enemies:
            if player.rect.colliderect(enemy.rect):
                if player.shield_timer <= 0:
                    time_left -= 4.0  # Ficou de plataforma, penalidade maior!
                enemy.speed_x *= -1
                enemy.speed_y *= -1

        if time_left <= 0:
            current_state = STATE_GAME_OVER

        # --- RENDERIZAÇÃO ---
        # Desenha Máquina do Tempo (Base)
        pygame.draw.rect(screen, GREEN, base_rect, 3)
        pygame.draw.rect(screen, (0, 60, 30), (base_rect.x+5, base_rect.y+5, base_rect.width-10, base_rect.height-10))
        
        # Desenha as Plataformas
        for plat in platforms:
            pygame.draw.rect(screen, GRAY, plat)
            pygame.draw.rect(screen, (100, 100, 120), plat, 1) # Detalhe de metal
        
        if not player.has_item: item.draw(screen)
        powerup.draw(screen)
        player.draw(screen)
        for enemy in enemies: enemy.draw(screen)

        # --- INTERFACE (UI) ---
        timer_color = RED if time_left <= 5 else WHITE
        timer_txt = font_lg.render(f"{max(0.0, time_left):.1f}s", True, timer_color)
        score_txt = font_sm.render(f"ENTREGAS: {deliveries_made}", True, WHITE)
        
        speed_percentage = int((player.speed_x / 4.5) * 100)
        speed_txt = font_sm.render(f"VELOCIDADE: {speed_percentage}%", True, CYAN)

        screen.blit(timer_txt, (WIDTH - 160, 20))
        screen.blit(score_txt, (20, HEIGHT - 75))
        screen.blit(speed_txt, (20, HEIGHT - 45))

        if player.shield_timer > 0:
            shield_txt = font_sm.render(f"ESCUDO: {player.shield_timer:.1f}s", True, BLUE)
            screen.blit(shield_txt, (20, HEIGHT - 105))

        pygame.display.flip()
        clock.tick(60)

    elif current_state == STATE_GAME_OVER:
        screen.fill((20, 5, 5)) 
        gameover_txt = font_lg.render("LINHA DE TEMPO COLAPSOU", True, RED)
        final_score_txt = font_md.render(f"Você estabilizou o portal {deliveries_made} vezes.", True, WHITE)
        restart_txt = font_sm.render("Pressione ESPAÇO para reiniciar o paradoxo", True, CYAN)
        
        screen.blit(gameover_txt, (WIDTH//2 - gameover_txt.get_width()//2, HEIGHT//3))
        screen.blit(final_score_txt, (WIDTH//2 - final_score_txt.get_width()//2, HEIGHT//2))
        screen.blit(restart_txt, (WIDTH//2 - restart_txt.get_width()//2, HEIGHT - 100))
        pygame.display.flip()
        
        for event in pygame.event.get():
            if event.type == pygame.QUIT: running = False
            if event.type == pygame.KEYDOWN and event.key == pygame.K_SPACE:
                current_state = STATE_MENU

pygame.quit()
sys.exit()

class ArduinoReader:
    def __init__(self, arduino):
        self.arduino = arduino
        self.running = True
        self.last_data = (0, 0, 0)
        self.lock = threading.Lock()
        self.thread = threading.Thread(target=self._read_loop, daemon=True)
        self.thread.start()
    
    def _read_loop(self):
        buffer = ""
        while self.running:
            if self.arduino and self.arduino.in_waiting > 0:
                try:
                    data = self.arduino.read(self.arduino.in_waiting).decode('utf-8', errors='ignore')
                    buffer += data
                    
                    while '\n' in buffer:
                        line, buffer = buffer.split('\n', 1)
                        line = line.strip()
                        if line:
                            dados = line.split(',')
                            if len(dados) == 3:
                                with self.lock:
                                    self.last_data = (int(dados[0]), int(dados[1]), int(dados[2]))
                except:
                    pass
            time.sleep(0.001)
    
    def get_data(self):
        with self.lock:
            return self.last_data
    
    def stop(self):
        self.running = False


class Player:
    def __init__(self):
        self.size = 25
        self.rect = pygame.Rect(0, 0, self.size, self.size)
        self.reset_pos()
        self.base_speed = 250.0
        self.dash_cooldown_max = 1.5
        self.shield_duration_max = 5.0
        self.speed = self.base_speed
        self.has_item = False
        self.shield_timer = 0.0
        self.dash_timer = 0.0
        self.dash_cooldown = 0.0
        self.dash_speed_multiplier = 3.5
        self.is_dashing = False
        self.move_dir = [0, 0]
        self.last_non_zero_dir = [1, 0]
        self.invincible_timer = 0.0
        self.dash_ghosts = []

    def reset_pos(self):
        self.rect.x = WIDTH // 2
        self.rect.y = HEIGHT // 2
        self.shield_timer = 0.0
        self.dash_timer = 0.0
        self.dash_cooldown = 0.0
        self.is_dashing = False
        self.invincible_timer = 0.0
        self.dash_ghosts = []

    def trigger_dash(self):
        if self.dash_cooldown <= 0 and (self.move_dir[0] != 0 or self.move_dir[1] != 0):
            self.is_dashing = True
            self.dash_timer = 0.15
            self.dash_cooldown = self.dash_cooldown_max

    def move(self, keys, arduino_inputs, obstacles, speed_zones, slow_zones, dt):
        if self.dash_cooldown > 0:
            self.dash_cooldown -= dt
        if self.invincible_timer > 0:
            self.invincible_timer -= dt
        if self.dash_timer > 0:
            self.dash_timer -= dt
            if self.dash_timer <= 0:
                self.is_dashing = False

        move_x, move_y = 0, 0
        
        if keys[pygame.K_LEFT] or keys[pygame.K_a]:
            move_x = -1
        if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
            move_x = 1
        if keys[pygame.K_UP] or keys[pygame.K_w]:
            move_y = -1
        if keys[pygame.K_DOWN] or keys[pygame.K_s]:
            move_y = 1
        if keys[pygame.K_LSHIFT] or keys[pygame.K_RSHIFT]:
            self.trigger_dash()

        ard_x, ard_y, ard_dash = arduino_inputs
        if ard_x != 0:
            move_x = ard_x
        if ard_y != 0:
            move_y = ard_y
        if ard_dash == 1:
            self.trigger_dash()

        if move_x != 0 or move_y != 0:
            length = math.sqrt(move_x**2 + move_y**2)
            self.move_dir = [move_x / length, move_y / length]
            self.last_non_zero_dir = self.move_dir
        else:
            self.move_dir = [0, 0]

        current_speed = self.speed
        if self.is_dashing:
            current_speed = self.speed * self.dash_speed_multiplier
            ghost_color = BLUE if self.has_item else CYAN
            self.dash_ghosts.append((self.rect.copy(), 0.15, ghost_color))
        else:
            if any(self.rect.colliderect(zone) for zone in speed_zones):
                current_speed = self.speed * 1.6
            elif any(self.rect.colliderect(zone) for zone in slow_zones):
                current_speed = self.speed * 0.5

        eff_dir = self.last_non_zero_dir if self.is_dashing else self.move_dir

        if eff_dir[0] != 0:
            self.rect.x += eff_dir[0] * current_speed * dt
            for obs in obstacles:
                if self.rect.colliderect(obs):
                    if eff_dir[0] > 0:
                        self.rect.right = obs.left
                    if eff_dir[0] < 0:
                        self.rect.left = obs.right

        if eff_dir[1] != 0:
            self.rect.y += eff_dir[1] * current_speed * dt
            for obs in obstacles:
                if self.rect.colliderect(obs):
                    if eff_dir[1] > 0:
                        self.rect.bottom = obs.top
                    if eff_dir[1] < 0:
                        self.rect.top = obs.bottom

        self.rect.clamp_ip(screen.get_rect())
        self.dash_ghosts = [(g[0], g[1] - dt, g[2]) for g in self.dash_ghosts if g[1] > 0]

    def draw(self, surface):
        for ghost, time_active, color in self.dash_ghosts:
            raw_alpha = int((time_active / 0.15) * 160)
            alpha = max(0, min(255, raw_alpha))
            s = pygame.Surface((self.size, self.size), pygame.SRCALPHA)
            s.fill((*color[:3], alpha))
            surface.blit(s, ghost.topleft)

        if self.invincible_timer > 0 and int(self.invincible_timer * 12) % 2 == 0:
            return

        pygame.draw.rect(surface, CYAN, self.rect)
        if self.has_item:
            pygame.draw.rect(surface, YELLOW, self.rect, 2)
        if self.shield_timer > 0:
            pygame.draw.rect(surface, BLUE, self.rect.inflate(10, 10), 3)

class Projectile:
    def __init__(self, x, y, tx, ty):
        self.size = 10
        self.rect = pygame.Rect(x, y, self.size, self.size)
        self.speed = 320.0
        dx = tx - x
        dy = ty - y
        dist = math.hypot(dx, dy)
        if dist != 0:
            self.vx = (dx / dist) * self.speed
            self.vy = (dy / dist) * self.speed
        else:
            self.vx, self.vy = self.speed, 0

    def update(self, dt):
        self.rect.x += self.vx * dt
        self.rect.y += self.vy * dt

    def draw(self, surface):
        pygame.draw.ellipse(surface, PINK, self.rect)
        pygame.draw.ellipse(surface, WHITE, self.rect.inflate(-4, -4), 1)

class Enemy:
    def __init__(self, obstacles, base_rect, enemy_type="BOUNCER"):
        self.size = 22
        self.rect = pygame.Rect(0, 0, self.size, self.size)
        self.type = enemy_type
        
        base_speed_mult = 1.0 + (current_phase - 1) * 0.12
        if enemy_type == "BOUNCER":
            self.speed = 160.0 * base_speed_mult
        elif enemy_type == "CHASER":
            self.speed = 110.0 * base_speed_mult
        elif enemy_type == "SNIPER":
            self.speed = 65.0 * base_speed_mult
        
        angle = random.uniform(0, 2 * math.pi)
        self.vx = math.cos(angle) * self.speed
        self.vy = math.sin(angle) * self.speed
        self.shoot_cooldown = random.uniform(1.0, 2.5)

        while True:
            self.rect.x = random.randint(100, WIDTH - 100)
            self.rect.y = random.randint(100, HEIGHT - 100)
            safe_center = pygame.Rect(WIDTH//2 - 100, HEIGHT//2 - 100, 200, 200)
            if self.rect.colliderect(safe_center) or self.rect.colliderect(base_rect):
                continue
            if any(self.rect.colliderect(obs) for obs in obstacles):
                continue
            break

    def update(self, player_rect, obstacles, dt):
        if self.type == "BOUNCER":
            self.rect.x += self.vx * dt
            self.rect.y += self.vy * dt
            if self.rect.left <= 0 or self.rect.right >= WIDTH:
                self.vx *= -1
            if self.rect.top <= 0 or self.rect.bottom >= HEIGHT:
                self.vy *= -1
        
        elif self.type == "CHASER":
            dx = player_rect.centerx - self.rect.centerx
            dy = player_rect.centery - self.rect.centery
            dist = math.hypot(dx, dy)
            if dist != 0:
                old_x = self.rect.x
                self.rect.x += (dx / dist) * self.speed * dt
                for obs in obstacles:
                    if self.rect.colliderect(obs):
                        self.rect.x = old_x
                
                old_y = self.rect.y
                self.rect.y += (dy / dist) * self.speed * dt
                for obs in obstacles:
                    if self.rect.colliderect(obs):
                        self.rect.y = old_y

        elif self.type == "SNIPER":
            dx = player_rect.centerx - self.rect.centerx
            dy = player_rect.centery - self.rect.centery
            dist = math.hypot(dx, dy)
            if dist > 180:
                old_x = self.rect.x
                self.rect.x += (dx / dist) * self.speed * dt
                for obs in obstacles:
                    if self.rect.colliderect(obs):
                        self.rect.x = old_x
                
                old_y = self.rect.y
                self.rect.y += (dy / dist) * self.speed * dt
                for obs in obstacles:
                    if self.rect.colliderect(obs):
                        self.rect.y = old_y

            self.shoot_cooldown -= dt
            if self.shoot_cooldown <= 0:
                projectiles.append(Projectile(self.rect.centerx, self.rect.centery,
                                            player_rect.centerx, player_rect.centery))
                self.shoot_cooldown = 2.5

    def draw(self, surface):
        if self.type == "CHASER":
            color = ORANGE
        elif self.type == "SNIPER":
            color = PURPLE
        else:
            color = RED
        
        pygame.draw.rect(surface, color, self.rect)
        pygame.draw.rect(surface, WHITE, self.rect, 1)


def create_hit_sound():
    try:
        import numpy as np
        sample_rate = 22050
        duration = 0.15
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples)
        envelope = np.exp(-t * 30)
        noise = np.random.normal(0, 0.3, samples)
        wave = noise * envelope
        wave = (wave * 32767).astype(np.int16)
        return pygame.sndarray.make_sound(wave)
    except:
        return pygame.mixer.Sound(buffer=bytes([0])*100)

def create_powerup_sound():
    try:
        import numpy as np
        sample_rate = 22050
        duration = 0.3
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples)
        freq = 440 + 220 * t / duration
        wave = np.sin(2 * np.pi * freq * t) * np.exp(-t * 5)
        wave = (wave * 32767).astype(np.int16)
        return pygame.sndarray.make_sound(wave)
    except:
        return pygame.mixer.Sound(buffer=bytes([0])*100)

def create_delivery_sound():
    try:
        import numpy as np
        sample_rate = 22050
        duration = 0.25
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples)
        wave = (np.sin(2 * np.pi * 523 * t) + np.sin(2 * np.pi * 659 * t) + np.sin(2 * np.pi * 784 * t)) / 3
        wave = wave * np.exp(-t * 3)
        wave = (wave * 32767).astype(np.int16)
        return pygame.sndarray.make_sound(wave)
    except:
        return pygame.mixer.Sound(buffer=bytes([0])*100)

def create_gameover_sound():
    try:
        import numpy as np
        sample_rate = 22050
        duration = 0.8
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples)
        freq = 440 - 200 * t / duration
        wave = np.sin(2 * np.pi * freq * t) * np.exp(-t * 2)
        wave = (wave * 32767).astype(np.int16)
        return pygame.sndarray.make_sound(wave)
    except:
        return pygame.mixer.Sound(buffer=bytes([0])*100)

def create_victory_sound():
    try:
        import numpy as np
        sample_rate = 22050
        duration = 0.6
        samples = int(sample_rate * duration)
        t = np.linspace(0, duration, samples)
        wave = (np.sin(2 * np.pi * 523 * t) + 
                np.sin(2 * np.pi * 659 * t) * 0.7 + 
                np.sin(2 * np.pi * 784 * t) * 0.5)
        wave = wave * np.exp(-t * 2)
        wave = (wave * 32767).astype(np.int16)
        return pygame.sndarray.make_sound(wave)
    except:
        return pygame.mixer.Sound(buffer=bytes([0])*100)


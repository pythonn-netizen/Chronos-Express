import sys

# 1. FORÇAR PARÂMETROS DE SEGURANÇA MÁXIMA ANTES DA JANELA
from panda3d.core import loadPrcFileData
loadPrcFileData("", "win-size 1280 720")
loadPrcFileData("", "fullscreen false")
loadPrcFileData("", "window-title Chronos - Emergency Mode")

# Caso sua GPU esteja rejeitando o OpenGL, o Panda3D tenta usar o modo de segurança de software
loadPrcFileData("", "load-display pandagl") 
loadPrcFileData("", "aux-display tinydisplay")

if sys.platform == "win32":
    try:
        import ctypes
        ctypes.windll.user32.SetProcessDPIAware()
    except:
        pass

from ursina import *
import random
import math

# Inicializa
app = Ursina()

# --- VARIÁVEIS DO JOGO ---
time_left = 30.0
deliveries_made = 0
has_item = False

# --- CONFIGURAÇÃO MANUAL DE CÂMERA (DIRETO NO MUNDO) ---
camera.orthographic = False
camera.position = (0, 15, -25)
camera.rotation_x = 30

# --- ELEMENTOS DO MAPA (APENAS CORES SÓLIDAS) ---
# Um chão simples e o cubo do jogador
floor = Entity(model='cube', scale=(300, 0.1, 300), y=0, color=color.dark_gray, collider='box')
player = Entity(model='cube', color=color.cyan, position=(0, 1.5, 0), scale=(1.5, 3, 1.5), collider='box')

# Alvos
base_delivery = Entity(model='cube', position=(-50, 3, 50), scale=(12, 6, 12), color=color.green, collider='box')
item = Entity(model='sphere', position=(50, 1.5, -50), scale=2, color=color.yellow)

# --- INTERFACE ULTRA SIMPLES (DIRETA NA TELA) ---
timer_text = Text(text='30.0s', position=(0.6, 0.4), scale=2.5, color=color.red)
score_text = Text(text='Entregas: 0', position=(-0.7, 0.4), scale=2, color=color.green)
status_text = Text(text='USE WASD PARA MOVER', position=(-0.2, 0.3), scale=1.5, color=color.yellow)

def update():
    global time_left, deliveries_made, has_item
    
    dt = min(time.dt, 0.03)
    time_left -= dt
    
    if time_left <= 0:
        time_left = 30.0
        player.position = (0, 1.5, 0)
        has_item = False
        item.enable()
    
    # Atualiza Textos
    timer_text.text = f"{max(0.0, time_left):.1f}s"
    score_text.text = f"Entregas: {deliveries_made}"
    
    # Movimentação direta pelas teclas WASD (Sem cálculo de rotação complexo para evitar travas)
    move_x = held_keys['d'] - held_keys['a']
    move_z = held_keys['w'] - held_keys['s']
    
    if move_x != 0 or move_z != 0:
        player.x += move_x * 35.0 * dt
        player.z += move_z * 35.0 * dt
        
    # Câmera segue rigidamente a posição do jogador
    camera.position = player.position + Vec3(0, 15, -25)
    
    # Lógica de proximidade básica (sem física complexa)
    if not has_item and distance(player.position, item.position) < 4.0:
        has_item = True
        item.disable()
        status_text.text = "LEVE A BATERIA ATE A BASE VERDE!"
        
    if has_item and distance(player.position, base_delivery.position) < 8.0:
        has_item = False
        deliveries_made += 1
        item.enable()
        status_text.text = "ENTREGA FEITA! BUSQUE OUTRA!"

app.run()
